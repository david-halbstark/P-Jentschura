{% liquid
  assign eyebrow_text = eyebrow
  assign eyebrow_variant = variant | default: 'u-eyebrow-main'
  assign eyebrow_classes = 'u-eyebrow-text'
  if eyebrow_variant != blank
    assign eyebrow_classes = eyebrow_classes | append: ' ' | append: eyebrow_variant
  endif
%}
                        {% if eyebrow_text != blank %}
                        <div class="u-eyebrow-wrapper">
                          <div class="u-eyebrow-layout">
                            <div class="{{ eyebrow_classes }}">
                              {{ eyebrow_text }}
                            </div>
                          </div>
                          {% endif %}
                        </div>
                        <div class="u-eyebrow-wrapper">
                          <div class="u-eyebrow-layout">
                            <div class="u-eyebrow-marker"></div>
                            <div class="u-eyebrow-text u-text-style-main w-richtext">
                              <p>Eyebrow Text Here</p>
                            </div>
                          </div>
                        </div>
                        {% render 'heading', visually_hidden: false, heading: section.settings.heading, tag: section.settings.heading_tag, variant: section.settings.heading_variant, tidy_text: false %}
                        <div data-preview-visibility="visible" data-number="20" data-wf--preview-heading--preview-variant="h2" class="u-heading w-variant-433d40c6-c261-f13f-c899-61d2cadf150f w-richtext">
                          <h2>Lorem ipsum dolor sit amet elit</h2>
                        </div>
                        <div class="u-button-wrapper">
                          <div class="u-display-contents">
                            <div data-wf--button-main--variant="primary" data-button=" " data-trigger="hover focus" class="button_main_wrap">
                              <div data-wf--clickable--variant="focus-ring-outside" class="clickable_wrap u-cover-absolute"><button type="button" aria-label="Button Text" class="clickable_btn"></button></div>
                              <div class="button_main_element">
                                <div aria-hidden="true" class="button_main_text u-text-style-main">Button Text</div>
                                <div class="button_main_icon u-hide-if-empty"></div>
                              </div>
                            </div>
                          </div>
                        </div>
