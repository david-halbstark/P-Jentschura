{% liquid assign heading_text = heading assign heading_tag = tag | default: 'h2' assign heading_variant = variant | default: 'u-text-style-h2' assign heading_custom_class = custom_class assign heading_max_width = max_width | default: '-1' assign heading_tidy_text = tidy_text | default: true assign heading_visually_hidden = visually_hidden | default: false assign heading_classes = 'u-heading' if heading_variant != blank assign heading_classes = heading_classes | append: ' ' | append: heading_variant endif if heading_custom_class != blank assign heading_classes = heading_classes | append: ' ' | append: heading_custom_class endif if heading_tidy_text assign heading_classes = heading_classes | append: ' u-text-wrap-default' endif if heading_visually_hidden assign heading_classes = heading_classes | append: ' u-sr-only' endif %}{% if heading_text != blank %}<div class="{{heading_classes}}" data-number="{{heading_max_width}}">{% case heading_tag %}{% when 'h1' %}<h1>{{heading_text}}</h1>{% when 'h2' %}<h2>{{heading_text}}</h2>{% when 'h3' %}<h3>{{heading_text}}</h3>{% when 'h4' %}<h4>{{heading_text}}</h4>{% when 'h5' %}<h5>{{heading_text}}</h5>{% when 'h6' %}<h6>{{heading_text}}</h6>{% else %}<h2>{{heading_text}}</h2>{% endcase %}</div>{% endif %}
                        {% if false %}    <div class="u-eyebrow-wrapper" li-if="false">
    
                          <div class="u-eyebrow-layout">
                            <div class="u-eyebrow-marker"></div>
                            <div class="u-eyebrow-text u-text-style-main w-richtext">
                              <p>Eyebrow Text Here</p>
                            </div>
                          </div>
                            </div>
{% endif %}
