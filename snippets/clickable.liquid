{% assign clickable_label = label -%}
{%- assign clickable_url = url -%}
{%- assign clickable_target = target | default: '_self' -%}
{%- assign clickable_mode = mode | default: 'link' -%}
{%- assign clickable_action = action -%}
{%- assign clickable_focus_ring = focus_ring | default: 'outside' -%}
{%- assign clickable_custom_class = custom_class -%}
{%- assign clickable_classes = 'clickable_wrap u-cover-absolute' -%}
{%- assign clickable_link_classes = 'clickable_link' -%}
{%- if clickable_custom_class != blank -%}
  {%- assign clickable_classes = clickable_classes | append: ' ' | append: clickable_custom_class -%}
{%- endif -%}
{%- if clickable_focus_ring == 'inside' -%}
  {%- assign clickable_link_classes = clickable_link_classes | append: ' u-focus-ring-inside' -%}
{%- endif -%}
{%- assign clickable_data_action = clickable_action -%}
{%- if clickable_mode == 'action' -%}
  {%- case clickable_action -%}
    {%- when 'newsletter_modal' -%}
      {%- assign clickable_data_action = 'open_newsletter_modal' -%}
    {%- when 'contact_modal' -%}
      {%- assign clickable_data_action = 'open_contact_modal' -%}
    {%- when 'copy_link' -%}
      {%- assign clickable_data_action = 'copy_link' -%}
  {%- endcase -%}
{%- endif -%}
{%- assign show_clickable = false -%}
{%- if clickable_label != blank -%}
  {%- if clickable_mode == 'link' and clickable_url != blank -%}
    {%- assign show_clickable = true -%}
  {%- elsif clickable_mode == 'action' and clickable_data_action != blank -%}
    {%- assign show_clickable = true -%}
  {%- elsif clickable_mode == 'submit' -%}
    {%- assign show_clickable = true -%}
  {%- endif -%}
{%- endif -%}
{%- if show_clickable %}
  <div class="{{clickable_classes}}">
    {% if clickable_mode == 'link' -%}
      <a
        href="{{clickable_url}}"
        target="{{clickable_target}}"
        aria-label="{{clickable_label | strip_html | escape}}"
        class="{{clickable_link_classes}}"
      ></a>
    {%- elsif clickable_mode == 'action' -%}
      <button
        type="button"
        aria-label="{{clickable_label | strip_html | escape}}"
        class="{{clickable_link_classes}}"
        data-action="{{clickable_data_action}}"
      ></button>
    {%- elsif clickable_mode == 'submit' -%}
      <button
        type="submit"
        aria-label="{{clickable_label | strip_html | escape}}"
        class="{{clickable_link_classes}}"
      ></button>
    {%- endif %}
  </div>
{% endif %}
