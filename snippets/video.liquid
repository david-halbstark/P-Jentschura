{% assign video_object = video %}

{% assign video_autoplay = autoplay | default: false %}
{% assign video_loop = loop | default: true %}
{% assign video_muted = muted | default: true %}
{% assign video_controls = controls | default: false %}
{% assign video_playsinline = playsinline | default: true %}
{% assign video_preload = preload | default: 'metadata' %}
{% assign video_play_behavior = play_behavior | default: 'none' %}

{% assign video_custom_class = custom_class %}
{% assign video_classes = 'u-video' %}

{% if video_custom_class != blank %}
  {% assign video_classes = video_classes | append: ' ' | append: video_custom_class %}
{% endif %}

{% assign video_behavior_value = video_play_behavior | replace: '_', '-' %}

{% assign video_poster_url = '' %}

{% if video_object.preview_image != blank %}
  {% assign video_poster_url = video_object.preview_image | image_url: width: 2000 %}
{% endif %}

{% assign video_open_tag = '<video class="' %}
{% assign video_open_tag = video_open_tag | append: video_classes %}
{% assign video_open_tag = video_open_tag | append: '"' %}

{% if video_behavior_value != blank %}
  {% assign video_open_tag = video_open_tag | append: ' data-video-behavior="' %}
  {% assign video_open_tag = video_open_tag | append: video_behavior_value %}
  {% assign video_open_tag = video_open_tag | append: '"' %}
{% endif %}

{% if video_preload != blank %}
  {% assign video_open_tag = video_open_tag | append: ' preload="' %}
  {% assign video_open_tag = video_open_tag | append: video_preload %}
  {% assign video_open_tag = video_open_tag | append: '"' %}
{% endif %}

{% if video_poster_url != blank %}
  {% assign video_open_tag = video_open_tag | append: ' poster="' %}
  {% assign video_open_tag = video_open_tag | append: video_poster_url %}
  {% assign video_open_tag = video_open_tag | append: '"' %}
{% endif %}

{% if video_autoplay %}
  {% assign video_open_tag = video_open_tag | append: ' autoplay' %}
{% endif %}

{% if video_loop %}
  {% assign video_open_tag = video_open_tag | append: ' loop' %}
{% endif %}

{% if video_muted %}
  {% assign video_open_tag = video_open_tag | append: ' muted' %}
{% endif %}

{% if video_controls %}
  {% assign video_open_tag = video_open_tag | append: ' controls' %}
{% endif %}

{% if video_playsinline %}
  {% assign video_open_tag = video_open_tag | append: ' playsinline' %}
{% endif %}

{% assign video_open_tag = video_open_tag | append: '>' %}

{% if video_object != blank %}
  {{ video_open_tag }}
  {% for source in video_object.sources %}
    {% if source.mime_type == 'video/mp4' %}
      <source src="{{ source.url }}" type="{{ source.mime_type }}">
    {% endif %}
  {% endfor %}
  </video>
{% endif %}
