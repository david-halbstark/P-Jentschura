{% liquid
  assign heading_text = heading
  assign heading_tag = tag | default: 'h2'
  assign heading_variant = variant | default: 'u-text-style-h2'
  assign heading_max_width = max_width
  assign heading_tidy_text = tidy_text
  assign heading_visually_hidden = visually_hidden
  assign heading_classes = 'u-headings'
  if heading_tidy_text
    assign heading_classes = heading_classes | append: ' u-text-wrap-default'
  endif
  if heading_visually_hidden
    assign heading_classes = heading_classes | append: ' u-visually-hidden'
  endif
%}
                        {% if heading_text != blank %}
                        <div class="{{ heading_classes }}" data-number="{{ heading_max_width }}">
                          {% case heading_tag %}
                          {% when 'h1' %}
                          <h1 class="{{ heading_variant }}">{{ heading_text }}</h1>
                          {% when 'h2' %}
                          <h2 class="{{ heading_variant }}">{{ heading_text }}</h2>
                          {% when 'h3' %}
                          <h3 class="{{ heading_variant }}">{{ heading_text }}</h3>
                          {% when 'h4' %}
                          <h4 class="{{ heading_variant }}">{{ heading_text }}</h4>
                          {% when 'h5' %}
                          <h5 class="{{ heading_variant }}">{{ heading_text }}</h5>
                          {% when 'h6' %}
                          <h6 class="{{ heading_variant }}">{{ heading_text }}</h6>
                          {% else %}
                          <h2 class="{{ heading_variant }}">{{ heading_text }}</h2>
                          {% endcase %}
                        </div>
                        {% endif %}
