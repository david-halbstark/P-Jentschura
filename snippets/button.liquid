{% assign button_label = label %}{% assign button_variant = variant | default: 'primary' %}{% assign button_mode = mode | default: 'link' %}{% assign button_url = url %}{% assign button_action = action %}{% assign button_custom_class = custom_class %}{% assign button_trigger = trigger %}{% assign button_variant_class = '' %}{% if button_variant == 'secondary' %}{% assign button_variant_class = 'w-variant-e85564cd-af30-a478-692b-71732aefb3ab' %}{% elsif button_variant == 'link' %}{% assign button_variant_class = 'w-variant-625d5df4-ad91-f7dc-9e2f-2e69f3fd7400' %}{% endif %}{% assign button_wrap_classes = 'button_main_wrap' %}{% assign button_element_classes = 'button_main_element' %}{% assign button_text_classes = 'button_main_text u-text-style-main' %}{% if button_variant_class != blank %}{% assign button_wrap_classes = button_wrap_classes | append: ' ' | append: button_variant_class %}{% assign button_element_classes = button_element_classes | append: ' ' | append: button_variant_class %}{% assign button_text_classes = button_text_classes | append: ' ' | append: button_variant_class %}{% endif %}{% if button_custom_class != blank %}{% assign button_wrap_classes = button_wrap_classes | append: ' ' | append: button_custom_class %}{% endif %}{% assign button_data_action = button_action %}{% if button_mode == 'action' %}{% case button_action %}{% when 'newsletter_modal' %}{% assign button_data_action = 'open_newsletter_modal' %}{% when 'contact_modal' %}{% assign button_data_action = 'open_contact_modal' %}{% endcase %}{% endif %}{% assign show_button = false %}{% if button_label != blank %}{% if button_mode == 'link' and button_url != blank %}{% assign show_button = true %}{% elsif button_mode == 'action' and button_data_action != blank %}{% assign show_button = true %}{% elsif button_mode == 'submit' %}{% assign show_button = true %}{% endif %}{% endif %}{% if show_button %}<div data-wf--preview-button-main--preview-variant="{{button_variant}}" data-trigger="{{button_trigger}}" class="{{button_wrap_classes}}"> <div class="clickable_wrap u-cover-absolute">{% if button_mode == 'link' %}<a aria-label="{{button_label}}" href="{{button_url}}" class="clickable_link"></a>{% elsif button_mode == 'action' %}<button type="button" aria-label="{{button_label}}" class="clickable_link" data-action="{{button_data_action}}"></button>{% elsif button_mode == 'submit' %}<button type="submit" aria-label="{{button_label}}" class="clickable_link" data-action="{{button_data_action}}"></button>{% endif %}</div> <div aria-hidden="true" class="{{button_element_classes}}"> <div class="{{button_text_classes}}">{{button_label}}</div> </div> </div>{% endif %}
