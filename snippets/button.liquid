{% assign button_label = label %}{% assign button_variant = variant | default: 'primary' %}{% assign button_mode = mode | default: 'link' %}{% assign button_url = url %}{% assign button_action = action %}{% assign button_custom_class = custom_class %}{% assign button_trigger = trigger %}{% assign button_classes = 'button_main_wrap' %}{% assign button_variant_attribute = '' %}{% if button_variant != blank and button_variant != 'primary' %}{% assign button_variant_attribute = 'data-wf--preview-button-main--preview-variant="' | append: button_variant | append: '"' %}{% endif %}{% if button_custom_class != blank %}{% assign button_classes = button_classes | append: ' ' | append: button_custom_class %}{% endif %}{% assign show_button = false %}{% if button_label != blank %}{% if button_mode == 'link' and button_url != blank %}{% assign show_button = true %}{% elsif button_mode == 'action' and button_action != blank %}{% assign show_button = true %}{% endif %}{% endif %}{% if show_button %}<div class="{{button_classes}}" button_trigger="" button_variant_attribute=""> <div class="clickable_wrap u-cover-absolute">{% if button_mode == 'link' %}<a href="{{button_url}}" class="clickable_link"></a>{% elsif button_mode == 'action' %}<button type="button" class="clickable_link" button_action=""></button>{% endif %}</div> <div class="button_main_element"> <div class="button_main_text">{{button_label}}</div> </div> </div>{% endif %}
