{% assign button_label = label %}{% assign button_variant = variant | default: 'primary' %}{% assign button_mode = mode | default: 'link' %}{% assign button_url = url %}{% assign button_attributes = attributes %}{% assign button_custom_class = custom_class %}{% assign button_classes = 'button' %}{% if button_variant != blank %}{% assign button_classes = button_classes | append: ' ' | append: button_variant %}{% endif %}{% if button_custom_class != blank %}{% assign button_classes = button_classes | append: ' ' | append: button_custom_class %}{% endif %}{% if button_label != blank %}{% if button_mode == 'action' %}<button type="button" class="{{button_classes}}" button_attributes=""> <span class="button_text">{{button_label}}</span> </button>{% elsif button_url != blank %}<a href="{{button_url}}" class="{{button_classes}}" button_attributes=""> <span class="button_text">{{button_label}}</span> </a>{% endif %}{% endif %}
