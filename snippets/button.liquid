ton_mode == 'action' and button_data_action != blank %}{% assign show_button = true %}{% elsif button_mode == 'submit' %}{% assign show_button = true %}{% endif %}{% endif %}{% if show_button %}<div data-wf--preview-button-main--preview-variant="{{button_variant}}" data-trigger="{{button_trigger}}" class="{{button_wrap_classes}}"> <div class="clickable_wrap u-cover-absolute">{% if button_mode == 'link' %}<a aria-label="{{button_label | strip_html | escape}}" href="{{button_url}}" class="clickable_link"></a>{% elsif button_mode == 'action' %}<button type="button" aria-label="{{button_label | strip_html | escape}}" class="clickable_link" data-action="{{button_data_action}}"></button>{% elsif button_mode == 'submit' %}<button type="submit" aria-label="{{button_label | strip_html | escape}}" class="clickable_link"></button>{% endif %}</div> <div aria-hidden="true" class="{{button_element_classes}}">{% if button_icon != blank and button_icon != 'none' and button_icon_position == 'before' %}{% render 'icon', icon: button_icon, color: button_icon_color, custom_class: 'button_main_icon' %}{% endif %}<div class="{{button_text_classes}}">{{button_label}}{% if button_variant == 'pill' and button_pill_tag_inner != blank %}<span class="button_main_tag_inner">{{button_pill_tag_inner}}</span>{% endif %}</div>{% if button_icon != blank and button_icon != 'none' and button_icon_position == 'after' %}{% render 'icon', icon: button_icon, color: button_icon_color, custom_class: 'button_main_icon' %}{% endif %}</div> </div>{% endif %}
