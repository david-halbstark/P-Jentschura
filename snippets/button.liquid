{% assign button_label = label %}{% assign button_variant = variant | default: 'primary' %}{% assign button_mode = mode | default: 'link' %}{% assign button_url = url %}{% assign button_action = action %}{% assign button_custom_class = custom_class %}{% assign button_trigger = trigger %}{% assign button_classes = 'button_main_wrap' %}{% if button_custom_class != blank %}{% assign button_classes = button_classes | append: ' ' | append: button_custom_class %}{% endif %}{% assign show_button = false %}{% if button_label != blank %}{% if button_mode == 'link' and button_url != blank %}{% assign show_button = true %}{% elsif button_mode == 'action' and button_action != blank %}{% assign show_button = true %}{% elsif button_mode == 'submit' %}{% assign show_button = true %}{% endif %}{% endif %}{% if show_button %}<div data-wf--preview-button-main--preview-variant="{{button_variant}}" data-trigger="{{button_trigger}}" class="{{button_classes}}"> <div class="clickable_wrap u-cover-absolute">{% if button_mode == 'link' %}<a aria-label="{{button_label}}" href="{{button_url}}" class="clickable_link"></a>{% elsif button_mode == 'action' %}<button type="button" aria-label="{{button_label}}" class="clickable_link" button_action=""></button>{% elsif button_mode == 'submit' %}<button type="submit" aria-label="{{button_label}}" class="clickable_link"></button>{% endif %}</div> <div aria-hidden="true" class="button_main_element"> <div class="button_main_text u-text-style-main">{{button_label}}</div> </div> </div>{% endif %}
