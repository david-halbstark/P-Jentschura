{% assign button_1_color = '' %}
{% assign button_1_text_size = '' %}
{% assign button_1_padding = '' %}

{% if button_1_variant == 'solid' %}
  {% assign button_1_color = button_1_solid_color %}
  {% assign button_1_text_size = button_1_solid_text_size %}
  {% assign button_1_padding = button_1_solid_padding %}
{% elsif button_1_variant == 'text' %}
  {% assign button_1_color = button_1_text_color %}
  {% assign button_1_text_size = button_1_text_text_size %}
{% elsif button_1_variant == 'pill' %}
  {% assign button_1_color = button_1_pill_color %}
  {% assign button_1_text_size = button_1_pill_text_size %}
{% endif %}

{% assign button_2_color = '' %}
{% assign button_2_text_size = '' %}
{% assign button_2_padding = '' %}

{% if button_2_variant == 'solid' %}
  {% assign button_2_color = button_2_solid_color %}
  {% assign button_2_text_size = button_2_solid_text_size %}
  {% assign button_2_padding = button_2_solid_padding %}
{% elsif button_2_variant == 'text' %}
  {% assign button_2_color = button_2_text_color %}
  {% assign button_2_text_size = button_2_text_text_size %}
{% elsif button_2_variant == 'pill' %}
  {% assign button_2_color = button_2_pill_color %}
  {% assign button_2_text_size = button_2_pill_text_size %}
{% endif %}

{% assign show_button_1 = false %}
{% assign show_button_2 = false %}

{% if button_1_label != blank %}
  {% if button_1_mode == 'action' and button_1_action != blank %}
    {% assign show_button_1 = true %}
  {% elsif button_1_mode == 'link' and button_1_url != blank %}
    {% assign show_button_1 = true %}
  {% elsif button_1_mode == 'submit' %}
    {% assign show_button_1 = true %}
  {% endif %}
{% endif %}

{% if button_2_label != blank %}
  {% if button_2_mode == 'action' and button_2_action != blank %}
    {% assign show_button_2 = true %}
  {% elsif button_2_mode == 'link' and button_2_url != blank %}
    {% assign show_button_2 = true %}
  {% elsif button_2_mode == 'submit' %}
    {% assign show_button_2 = true %}
  {% endif %}
{% endif %}

{% if show_button_1 or show_button_2 %}
  <div class="u-button-wrapper">
    {% if show_button_1 %}
      {% render 'button',
        label: button_1_label,
        mode: button_1_mode,
        url: button_1_url,
        action: button_1_action,
        variant: button_1_variant,
        color: button_1_color,
        text_size: button_1_text_size,
        padding: button_1_padding,
        underline: button_1_underline,
        pill_tag_inner: button_1_pill_tag_inner,
        icon: button_1_icon,
        icon_position: button_1_icon_position,
        icon_animation: button_1_icon_animation,
        trigger: button_1_trigger,
        custom_class: button_1_custom_class
      %}
    {% endif %}

    {% if show_button_2 %}
      {% render 'button',
        label: button_2_label,
        mode: button_2_mode,
        url: button_2_url,
        action: button_2_action,
        variant: button_2_variant,
        color: button_2_color,
        text_size: button_2_text_size,
        padding: button_2_padding,
        underline: button_2_underline,
        pill_tag_inner: button_2_pill_tag_inner,
        icon: button_2_icon,
        icon_position: button_2_icon_position,
        icon_animation: button_2_icon_animation,
        trigger: button_2_trigger,
        custom_class: button_2_custom_class
      %}
    {% endif %}
  </div>
{% endif %}
