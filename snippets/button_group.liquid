{% assign button_1_color = '' -%}
{%- assign button_1_text_size = '' -%}
{%- assign button_1_padding = '' -%}
{%- if button_1_variant == 'solid' -%}
  {%- assign button_1_color = button_1_solid_color -%}
  {%- assign button_1_text_size = button_1_solid_text_size -%}
  {%- assign button_1_padding = button_1_solid_padding -%}
{%- elsif button_1_variant == 'transparent' -%}
  {%- assign button_1_color = button_1_transparent_color -%}
  {%- assign button_1_text_size = button_1_transparent_text_size -%}
  {%- assign button_1_padding = button_1_transparent_padding -%}
{%- elsif button_1_variant == 'text' -%}
  {%- assign button_1_text_size = button_1_text_text_size -%}
{%- elsif button_1_variant == 'pill' -%}
  {%- assign button_1_color = button_1_pill_color -%}
  {%- assign button_1_text_size = button_1_pill_text_size -%}
{%- endif -%}
{%- assign button_2_color = '' -%}
{%- assign button_2_text_size = '' -%}
{%- assign button_2_padding = '' -%}
{%- if button_2_variant == 'solid' -%}
  {%- assign button_2_color = button_2_solid_color -%}
  {%- assign button_2_text_size = button_2_solid_text_size -%}
  {%- assign button_2_padding = button_2_solid_padding -%}
{%- elsif button_2_variant == 'transparent' -%}
  {%- assign button_2_color = button_2_transparent_color -%}
  {%- assign button_2_text_size = button_2_transparent_text_size -%}
  {%- assign button_2_padding = button_2_transparent_padding -%}
{%- elsif button_2_variant == 'text' -%}
  {%- assign button_2_text_size = button_2_text_text_size -%}
{%- elsif button_2_variant == 'pill' -%}
  {%- assign button_2_color = button_2_pill_color -%}
  {%- assign button_2_text_size = button_2_pill_text_size -%}
{%- endif -%}
{%- assign show_button_1 = false -%}
{%- assign show_button_2 = false -%}
{%- if button_1_label != blank -%}
  {%- if button_1_mode == 'action' and button_1_action != blank -%}
    {%- assign show_button_1 = true -%}
  {%- elsif button_1_mode == 'link' and button_1_url != blank -%}
    {%- assign show_button_1 = true -%}
  {%- elsif button_1_mode == 'submit' -%}
    {%- assign show_button_1 = true -%}
  {%- endif -%}
{%- endif -%}
{%- if button_2_label != blank -%}
  {%- if button_2_mode == 'action' and button_2_action != blank -%}
    {%- assign show_button_2 = true -%}
  {%- elsif button_2_mode == 'link' and button_2_url != blank -%}
    {%- assign show_button_2 = true -%}
  {%- elsif button_2_mode == 'submit' -%}
    {%- assign show_button_2 = true -%}
  {%- endif -%}
{%- endif %}
{% if show_button_1 or show_button_2 %}
  <div li-if="show_button_1 or show_button_2" class="u-button-wrapper">
    {% render 'button',
      url: button_1_url,
      icon_position: button_1_icon_position,
      action: button_1_action,
      padding: button_1_padding,
      text_size: button_1_text_size,
      icon: button_1_icon,
      label: button_1_label,
      icon_color: button_1_icon_color,
      trigger: button_1_trigger,
      icon_animation: button_1_icon_animation,
      mode: button_1_mode,
      color: button_1_color,
      custom_class: button_1_custom_class,
      pill_tag_inner: button_1_pill_tag_inner,
      variant: button_1_variant,
      underline: button_1_underline
    %}
    {% render 'button',
      url: button_2_url,
      icon_position: button_2_icon_position,
      action: button_2_action,
      padding: button_2_padding,
      text_size: button_2_text_size,
      icon: button_2_icon,
      label: button_2_label,
      icon_color: button_2_icon_color,
      trigger: button_2_trigger,
      icon_animation: button_2_icon_animation,
      mode: button_2_mode,
      color: button_2_color,
      custom_class: button_2_custom_class,
      pill_tag_inner: button_2_pill_tag_inner,
      variant: button_2_variant,
      underline: button_2_underline
    %}
  </div>
{% endif %}
{% if false %}
  <div li-if="false" class="u-button-wrapper">
    <div class="u-display-contents">
      <div data-button=" " data-trigger="hover focus" class="button_wrap">
        <div data-wf--clickable--variant="focus-ring-outside" class="clickable_wrap u-cover-absolute">
          <button type="button" aria-label="Button Text" class="clickable_btn"></button>
        </div>
        <div class="button_element">
          <div aria-hidden="true" class="button_text u-text-link-large">Button Text</div>
          <div class="button_icon u-hide-if-empty">
            <div class="u-display-contents">
              <div aria-hidden="true" data-wf--preview-icon--variant="full" class="u-icon w-embed">
                <svg xmlns="http://www.w3.org/2000/svg" width="66" height="70" viewbox="0 0 66 70" fill="none">
                  <path d="M17 2L50 34.9999L17 68" stroke="white" stroke-width="2"></path>
                </svg>
              </div>
            </div>
          </div>
        </div>
        <div data-wf--preview-button-variant--variant="solid" class="u-display-none"></div>
      </div>
      <div data-button=" " data-trigger="hover focus" class="button_wrap">
        <div data-wf--clickable--variant="focus-ring-outside" class="clickable_wrap u-cover-absolute">
          <button type="button" aria-label="Button Text" class="clickable_btn"></button>
        </div>
        <div class="button_element">
          <div aria-hidden="true" class="button_text u-text-link-large">Button Text</div>
          <div class="button_icon u-hide-if-empty"></div>
        </div>
        <div data-wf--preview-button-variant--variant="solid" class="u-display-none"></div>
      </div>
    </div>
  </div>
{% endif %}
<div class="u-display-none w-embed">
  <style>
      /* Button */
      .button_wrap {
        --button-bg-color: transparent;
        --button-bg-color-hover: transparent;
        --button-text-color: inherit;
        --button-text-color-hover: inherit;
        --button-border-color: transparent;
        --button-border-color-hover: transparent;
      }
      .button_element {
        font-size: var(--button-text-size);
        color: color-mix(in srgb, var(--button-text-color) calc(100% * var(--_trigger---on)), var(--button-text-color-hover) calc(100% * var(--_trigger---off)));
        background-color: color-mix(in srgb, var(--button-bg-color) calc(100% * var(--_trigger---on)), var(--button-bg-color-hover) calc(100% * var(--_trigger---off)));
        border-color: color-mix(in srgb, var(--button-border-color) calc(100% * var(--_trigger---on)), var(--button-border-color-hover) calc(100% * var(--_trigger---off)));
      }
      /*  Button Variant Solid  */
      /*  BG Red  */
      .button_wrap.is-variant-solid.is-bg-red {
        --button-bg-color: var(--swatch--crimson);
        --button-bg-color-hover: var(--swatch--crimson-darker);
        --button-text-color: var(--swatch--white);
        --button-text-color-hover: var(--swatch--white);
      }
      /*  BG White  */
      .button_wrap.is-variant-solid.is-bg-white {
        --button-bg-color: var(--swatch--white);
        --button-bg-color-hover: var(--swatch--snow);
        --button-text-color: var(--swatch--charcoal);
        --button-text-color-hover: var(--swatch--charcoal);
      }
      /* Padding Base */
    .button_wrap.is-padding-base .button_element {
      padding: 3.5rem 1.25rem;
    }
  </style>
</div>
