{% assign image_object = image %}
{% assign image_object_mobile = image_mobile %}

{% assign image_width = width | default: 2000 %}
{% assign image_width_mobile = width_mobile | default: 900 %}
{% assign image_breakpoint = breakpoint | default: '767px' %}

{% assign image_loading = loading | default: 'lazy' %}
{% assign image_fetchpriority = fetchpriority %}
{% assign image_alt = alt %}
{% assign image_sizes = sizes | default: '100vw' %}

{% assign image_custom_class = custom_class %}
{% assign image_wrapper_class = wrapper_class %}

{% if image_object != blank %}
  {% if image_wrapper_class != blank %}
    <div class="{{ image_wrapper_class }}">
  {% endif %}

  {% capture desktop_image %}
    {% if image_fetchpriority != blank %}
      {{
        image_object
        | image_url: width: image_width
        | image_tag:
          class: image_custom_class,
          loading: image_loading,
          fetchpriority: image_fetchpriority,
          alt: image_alt,
          sizes: image_sizes
      }}
    {% else %}
      {{
        image_object
        | image_url: width: image_width
        | image_tag:
          class: image_custom_class,
          loading: image_loading,
          alt: image_alt,
          sizes: image_sizes
      }}
    {% endif %}
  {% endcapture %}

  {% if image_object_mobile != blank %}
    <picture>
      <source
        media="(max-width: {{ image_breakpoint }})"
        srcset="{{ image_object_mobile | image_url: width: image_width_mobile }}"
      >

      {{ desktop_image }}
    </picture>
  {% else %}
    {{ desktop_image }}
  {% endif %}

  {% if image_wrapper_class != blank %}
    </div>
  {% endif %}
{% endif %}
