                                  <div class="testimonial_slider_card_star">
                                    {% render 'icon', custom_class: , icon: 'star', aria-hidden: true %}
                                  </div>
                                  <div class="testimonial_slider_card_star">
                                    {% render 'icon', custom_class: , icon: 'star', aria-hidden: true %}
                                  </div>
                                  <div class="testimonial_slider_card_star">
                                    {% render 'icon', custom_class: , icon: 'star', aria-hidden: true %}
                                  </div>
                                </div>
                                {% render 'typography', custom_class: 'u-margin-bottom-0 u-min-width-auto', text: testimonial.rating_text.value, tag: 'span', variant: 'u-text-body-base' %}
                              </div>
                              {% render 'heading', tag: section.settings.heading_tag, visually_hidden: section.settings.heading_visually_hidden, tidy_text: section.settings.heading_tidy_text, heading: testimonial.title.value, custom_class: 'u-margin-bottom-0', variant: section.settings.heading_variant, max_width: section.settings.heading_max_width %}
                              {% render 'paragraph', tidy_text: section.settings.paragraph_tidy_text, custom_class: 'u-margin-bottom-0', paragraph: section.settings.paragraph, variant: section.settings.paragraph_variant, max_width: section.settings.paragraph_max_width %}
