                  <div class="recipe_slider_slider_element swiper">
                    <div li-for:inside="recipe in sorted_recipes" class="recipe_slider_slider_list swiper-wrapper">
        {% for recipe in sorted_recipes %}                            
                      
                            <div class="recipe_slider_slider_slide swiper-slide">
