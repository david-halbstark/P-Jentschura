        <div class="recipe_slider_contain u-container" {% if section.settings.section_id != blank %}id='{{ section.settings.section_id }}'{% endif %}>
          
          <div class="recipe_slider_layout">
            <div class="recipe_slider_left">
              <div class="recipe_slider_left_top">
                {% render 'eyebrow', tag: section.settings.eyebrow_tag, eyebrow: section.settings.eyebrow, variant: 'u-text-eyebrow-base', wrapper_class: 'is-eyebrow-base u-color-3' %}
                {% render 'heading', tidy_text: section.settings.heading_tidy_text, heading: section.settings.heading, tag: section.settings.heading_tag, variant: 'u-text-h2-primary', max_width: section.settings.heading_max_width %}
                {% render 'paragraph', tidy_text: section.settings.paragraph_tidy_text, custom_class: 'u-color-3', paragraph: section.settings.paragraph, variant: 'u-text-body-base', max_width: section.settings.paragraph_max_width %}
                {% render 'button_group', button_1_solid_color: 'red', button_1_url: section.settings.button_1_url, button_1_label: section.settings.button_1_label, button_1_trigger: 'hover focus', button_1_solid_padding: 'base', button_1_solid_text_size: 'u-text-link-large', button_1_mode: 'link', button_1_variant: 'solid' %}
              </div>
              <div class="recipe_slider_left_bot">
                <div class="slider_controls">
                  <div class="slider_bullet_list">
                    <div class="slider_bullet_item is-active"></div>
                    <div class="slider_bullet_item"></div>
                  </div>
                  <div class="slider_button_layout"><button data-trigger="hover focus" class="slider_button_wrap is-prev">
                      <div class="slider_button_element">
                        <div class="slider_button_icon">
                          {% render 'icon', aria-hidden: true, icon: 'arrow_left' %}
                        </div>
                      </div>
                    </button><button data-trigger="hover focus" class="slider_button_wrap is-next">
                      <div class="slider_button_element">
                        <div class="slider_button_icon">
                          {% render 'icon', aria-hidden: true, icon: 'arrow_right' %}
                        </div>
                      </div>
                    </button></div>
                </div>
              </div>
            </div>
            <div class="recipe_slider_right"></div>
          </div>
          
