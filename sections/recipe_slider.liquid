                              <div class="recipe_slider_tag">
                                {% render 'tag', solid_color: 'green', tag: recipe.metafields.custom.tag.value.title.value, variant: 'solid', solid_text_size: 'u-text-eyebrow-small' %}
                              </div>
                            </div>
                            <div class="recipe_slider_card_bot">
                              <div class="recipe_slider_card_bot_top">
                                <div class="recipe_slider_card_text">
                                  {% render 'heading', custom_class: 'u-margin-bottom-0', heading: recipe.title.value, tag: 'h3', variant: 'u-text-h4-primary' %}
                                  {% render 'paragraph', variant: 'u-text-body-base', custom_class: 'u-margin-bottom-0 u-color-3', paragraph: section.settings.paragraph %}
                                </div>
                              </div>
                              <div class="recipe_slider_card_meta">
                                {% render 'typography', custom_class: 'u-margin-bottom-0 u-min-width-auto u-color-3', text: recipe.difficulty.value, tag: 'span', variant: 'u-text-body-small' %}
                                {% render 'typography', custom_class: 'u-margin-bottom-0 u-min-width-auto u-color-3', text: recipe.preperation_time.value, tag: 'span', variant: 'u-text-body-small' %}
                                {% render 'typography', custom_class: 'u-margin-bottom-0 u-min-width-auto u-color-3', text: recipe.serving.value, tag: 'span', variant: 'u-text-body-small' %}
                              </div>
                              <div class="recipe_slider_card_button_wrap">
                                <div class="recipe_slider_card_button_element">
                                  <div class="recipe_slider_card_button_inner">
                                    {% render 'button_group', button_1_solid_color: 'red', button_1_url: recipe.system.url, button_1_label: section.settings.card_button_label, button_1_trigger: 'hover focus', button_1_solid_padding: 'base', button_1_solid_text_size: 'u-text-link-large', button_1_mode: ‘link', button_1_variant: 'solid', button_1_custom_class: %}
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                            
                      
                            
                            
                      
                            
                            
                      
                            
                            
                      
                            
                            
                    
