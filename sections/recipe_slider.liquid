        <div class="u-embed-js w-embed w-script">
          <script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.recipe_slider_layout').forEach((component) => {
      if (component.dataset.scriptInitialized === 'true') return;
      const swiperElement = component.querySelector(
        '.recipe_slider_slider_element.swiper'
      );
      if (!swiperElement || swiperElement.swiper) return;
      // Navigation und Pagination liegen im Layout-Component
      const previousButton = component.querySelector(
        '.slider_button_wrap.is-prev'
      );
      const nextButton = component.querySelector(
        '.slider_button_wrap.is-next'
      );
      const pagination = component.querySelector('.slider_bullet_list');
      component.dataset.scriptInitialized = 'true';
      const swiperOptions = {
        slidesPerView: 'auto',
      };
      // Navigation nur initialisieren, wenn beide Buttons existieren
      if (previousButton && nextButton) {
        swiperOptions.navigation = {
          prevEl: previousButton,
          nextEl: nextButton,
          disabledClass: 'is-disabled',
        };
      }
      // Pagination nur initialisieren, wenn das Element existiert
      if (pagination) {
        swiperOptions.pagination = {
          el: pagination,
          clickable: true,
          bulletClass: 'slider_bullet_item',
          bulletActiveClass: 'is-active',
          renderBullet(index, className) {
            return `
              <button
                type="button"
                class="${className}"
                aria-label="Slide ${index + 1}"
              ></button>
            `;
          },
        };
      }
      new Swiper(swiperElement, swiperOptions);
    });
  });
</script>
