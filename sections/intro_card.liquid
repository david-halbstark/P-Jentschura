<div class="u-embed-css w-embed">
  <style>
    .intro_card_top .u-heading > * {
      width: 100%;
    }
    .intro_card_items .intro_card_item_wrap:not(:last-child) .intro_card_item_element > ::after {
      content: '\00a0\2022  ';
      display: inline;
      color: var(--_theme---text-4);
    }
    .intro_card_item_element span.u-text,
    .intro_card_item_element::after {
      display: inline;
    }
    .intro_card_item_element span::before {
      content: none !important;
    }
  </style>
</div>

<div class="u-display-none"></div>
<div class="u-display-none">
  {% case section.settings.spacing_top -%}
    {%- when 'xxsmall' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--xxsmall)' -%}
    {%- when 'xsmall' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--xsmall)' -%}
    {%- when 'small' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--small)' -%}
    {%- when 'medium' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--medium)' -%}
    {%- when 'large' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--large)' -%}
    {%- when 'large_medium_off' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--large-medium-off)' -%}
    {%- when 'page_top' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--page-top)' -%}
    {%- else -%}
      {%- assign spacing_top = '0' -%}
  {%- endcase -%}
  {%- case section.settings.spacing_bottom -%}
    {%- when 'xxsmall' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--xxsmall)' -%}
    {%- when 'xsmall' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--xsmall)' -%}
    {%- when 'small' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--small)' -%}
    {%- when 'medium' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--medium)' -%}
    {%- when 'large' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--large)' -%}
    {%- when 'page_top' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--page-top)' -%}
    {%- else -%}
      {%- assign spacing_bottom = '0' -%}
  {%- endcase %}
  <div class="u-embed-css w-embed">
    <style>
      #shopify-section-{{ section.id }} [data-section-spacing] {
        --section-spacing-top: {{ spacing_top }};
        --section-spacing-bottom: {{ spacing_bottom }};
      }
    </style>
  </div>
</div>
<div class="u-display-none"></div>
<div class="u-display-none"></div>
<div
  class="intro_card_contain u-container"
  {% if section.settings.section_id != blank %}
    id="{{ section.settings.section_id | handleize }}"
  {% endif %}
>
  <div data-section-spacing="" class="intro_card_layout">
    <div class="intro_card_inner">
      <div class="intro_card_top">
        {% render 'heading',
          custom_class: 'u-margin-bottom-0 u-min-width-auto',
          heading: section.settings.heading,
          tag: 'h2',
          variant: 'u-text-h1-secondary',
          max_width: section.settings.heading_max_width,
          tidy_text: section.settings.heading_tidy_text
        %}
        <div class="intro_card_items">
          {% for block in section.blocks %}
            {% if block.type == 'item' %}
              <div li-block="Item" class="intro_card_item_wrap u-display-contents">
                <div class="intro_card_item_element u-display-contents">
                  <div class="u-display-none"></div>
                  {% render 'typography',
                    custom_class: 'u-margin-bottom-0 u-min-width-auto u-color-3',
                    text: block.settings.text,
                    tag: 'span',
                    variant: 'u-text-body-small'
                  %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="intro_card_bot">
        {% render 'paragraph',
          tidy_text: section.settings.paragraph_tidy_text,
          custom_class: 'u-margin-bottom-0',
          paragraph: section.settings.paragraph,
          variant: 'u-text-body-large',
          max_width: section.settings.paragraph_max_width
        %}
      </div>
    </div>
  </div>
</div>
<div class="u-heading"></div>
