        },
        {
          "value": "xxsmall",
          "label": "Extra extra klein"
        },
        {
          "value": "xsmall",
          "label": "Extra klein"
        },
        {
          "value": "small",
          "label": "Klein"
        },
        {
          "value": "medium",
