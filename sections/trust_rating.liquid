        <div class="u-display-none">
          
          
          
          {% case section.settings.spacing_top %}{% when 'xxsmall' %}{% assign spacing_top = 'var(--_spacing---section-space--xxsmall)' %}{% when 'xsmall' %}{% assign spacing_top = 'var(--_spacing---section-space--xsmall)' %}{% when 'small' %}{% assign spacing_top = 'var(--_spacing---section-space--small)' %}{% when 'medium' %}{% assign spacing_top = 'var(--_spacing---section-space--medium)' %}{% when 'large' %}{% assign spacing_top = 'var(--_spacing---section-space--large)' %}{% when 'page_top' %}{% assign spacing_top = 'var(--_spacing---section-space--page-top)' %}{% else %}{% assign spacing_top = '0' %}{% endcase %}{% case section.settings.spacing_bottom %}{% when 'xxsmall' %}{% assign spacing_bottom = 'var(--_spacing---section-space--xxsmall)' %}{% when 'xsmall' %}{% assign spacing_bottom = 'var(--_spacing---section-space--xsmall)' %}{% when 'small' %}{% assign spacing_bottom = 'var(--_spacing---section-space--small)' %}{% when 'medium' %}{% assign spacing_bottom = 'var(--_spacing---section-space--medium)' %}{% when 'large' %}{% assign spacing_bottom = 'var(--_spacing---section-space--large)' %}{% when 'page_top' %}{% assign spacing_bottom = 'var(--_spacing---section-space--page-top)' %}{% else %}{% assign spacing_bottom = '0' %}{% endcase %}
          {% style %}#shopify-section-{{section.id}}[data-section-spacing]{--section-spacing-top:{{spacing_top}}; --section-spacing-bottom:{{spacing_bottom}};}{% endstyle %}
        </div>
        <div class="u-display-none">
          
          
        </div>
        <div class="trust_rating_contain u-container" id="{% if section.settings.section_id != blank %}{{ section.settings.section_id }}{% endif %}">
          
          <div data-element="layout" class="trust_rating_layout">
            {% render 'heading', tag: section.settings.heading_tag, visually_hidden: true, tidy_text: section.settings.heading_tidy_text, heading: section.settings.heading, custom_class: , variant: section.settings.heading_variant, max_width: section.settings.heading_max_width %}
            <div class="trust_rating_left">
              <div class="trust_rating_stars">
                <div class="trust_rating_star">
                  {% render 'icon', custom_class: , icon: 'star', aria-hidden: true %}
                </div>
                <div class="trust_rating_star">
                  {% render 'icon', custom_class: , icon: 'star', aria-hidden: true %}
                </div>
                <div class="trust_rating_star">
                  {% render 'icon', custom_class: , icon: 'star', aria-hidden: true %}
                </div>
                <div class="trust_rating_star">
