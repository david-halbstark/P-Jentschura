<div class="u-display-none"></div>
<div class="u-display-none"></div>
<div class="hero_main_slider_wrap u-position-relative">
  <div class="hero_main_slider_offset">
    <div class="hero_main_slider_element swiper">
      <div class="hero_main_slider_list swiper-wrapper">
        <div class="hero_main_slide_wrap swiper-slide">
          <div class="hero_main_slide_background u-cover-absolute">
            <img
              src="{{ 'lumos-v2.webp' | asset_url }}"
              loading="lazy"
              sizes="(max-width: 1920px) 100vw, 1920px"
              srcset="{{ 'lumos-v2-p-500.webp' | asset_url }} 500w, {{ 'lumos-v2-p-800.webp' | asset_url }} 800w, {{ 'lumos-v2-p-1080.webp' | asset_url }} 1080w, {{ 'lumos-v2-p-1600.webp' | asset_url }} 1600w, {{ 'lumos-v2.webp' | asset_url }} 1920w"
              alt=""
              class="hero_main_slide_image u-cover-absolute"
            >
            <div class="hero_main_slide_overlay u-cover-absolute"></div>
          </div>
          <div class="hero_main_slide_contain u-container">
            <div
              data-wf--spacer--variant="main"
              class="u-section-spacer w-variant-60a7ad7d-02b0-6682-95a5-2218e6fd1490 u-ignore-trim"
            ></div>
            <div class="hero_main_slide_content">
              <div class="u-eyebrow-wrapper">
                <div class="u-eyebrow-layout">
                  <div class="u-eyebrow-marker"></div>
                  <div class="u-eyebrow-text u-text-style-main w-richtext">
                    <p>Eyebrow Text Here</p>
                  </div>
                </div>
              </div>
              {% render 'heading', variant: section.settings.heading_variant, heading: section.settings.heading %}
              <div
                data-preview-visibility="visible"
                data-number="4"
                data-wf--preview-heading--variant="h2"
                class="u-heading w-variant-433d40c6-c261-f13f-c899-61d2cadf150f w-richtext"
              >
                <h2>Lorem ipsum dolor sit amet elit</h2>
              </div>
              <div class="u-button-wrapper">
                <div class="u-display-contents">
                  <div
                    data-wf--button-main--variant="primary"
                    data-button=" "
                    data-trigger="hover focus"
                    class="button_main_wrap"
                  >
                    <div data-wf--clickable--variant="focus-ring-outside" class="clickable_wrap u-cover-absolute">
                      <button type="button" aria-label="Button Text" class="clickable_btn"></button>
                    </div>
                    <div class="button_main_element">
                      <div aria-hidden="true" class="button_main_text u-text-style-main">Button Text</div>
                      <div class="button_main_icon u-hide-if-empty"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div
              data-wf--spacer--variant="main"
              class="u-section-spacer w-variant-60a7ad7d-02b0-6682-95a5-2218e6fd1490 u-ignore-trim"
            ></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="hero_main_slider_controls u-container">
    <div class="hero_main_slider_bullet_list">
      <div class="hero_main_slider_bullet_item"></div>
      <div class="hero_main_slider_bullet_item is-active"></div>
    </div>
  </div>
</div>
<div></div>
{% schema %}
{
  "tag": "section",
  "name": "Trust Rating",
  "class": "hero_main_wrap u-section",
  "settings": [
    {
      "type": "header",
      "content": "Sektion"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "ID"
    },
    {
      "type": "header",
      "content": "\u00dcberschrift"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Text",
      "default": "Lorem ipsum dolor sit amet elit"
    },
    {
      "type": "select",
      "id": "heading_variant",
      "label": "Heading Variant",
      "options": [
        {
          "value": "u-text-style-h1",
          "label": "H1"
        },
        {
          "value": "u-text-style-h2",
          "label": "H2"
        },
        {
          "value": "u-text-style-h3",
          "label": "H3"
        },
        {
          "value": "u-text-style-h4",
          "label": "H4"
        },
        {
          "value": "u-text-style-h5",
          "label": "H5"
        },
        {
          "value": "u-text-style-h6",
          "label": "H6"
        }
      ],
      "default": "u-text-style-h2"
    },
    {
      "type": "number",
      "id": "heading_max_width",
      "label": "Heading Max Width",
      "default": 20
    },
    {
      "type": "text",
      "id": "heading_id",
      "label": "Heading ID"
    }
  ],
  "presets": [
    {
      "name": "Trust Rating",
      "category": "Liquify",
      "blocks": []
    }
  ]
}
{% endschema %}
