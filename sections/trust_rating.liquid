                </div>
                <div class="trust_rating_star">
                  {% render 'icon', custom_class: , icon: 'star', aria-hidden: true %}
                </div>
              </div>
              {% render 'typography', custom_class: 'u-margin-bottom-0', text: settings.proven_expert_rating, tag: 'div', variant: 'u-text-link-base' %}
            </div>
            <div class="trust_rating_right">
              {% render 'typography', custom_class: 'u-margin-bottom-0', text: settings.proven_expert_reviews_count, tag: 'div', variant: 'u-text-body-base' %}
              <div class="trust_rating_logo">
                {% render 'image', width: 248, image: settings.proven_expert_logo, object_fit: 'contain' %}
              </div>
            </div>
