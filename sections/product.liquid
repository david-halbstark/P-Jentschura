<div class="u-embed-css w-embed">
  <style>
    .product_breadcrumbs_element .u-text::before,
    .product_breadcrumbs_element .u-text::after,
    .product_breadcrumbs_element .u-text span::before,
    .product_breadcrumbs_element .u-text span::after {
      content: none !important;
    }
    .product_breadcrumbs_item:not(:last-child)::after {
      content: '\00a0\00a0\203A\00a0   ' !important;
      display: inline;
    }
    @container (width < 53em) {
      .product_layout {
        grid-template-columns: 1fr;
        grid-template-areas:
          'breadcrumbs'
          'gallery'
          'summary'
          'story'
          'journeys'
          'details'
          'complements'
          'links';
      }
      .product_gallery_wrap {
        grid-area: gallery;
      }
      .product_story_wrap {
        grid-area: story;
      }
      .product_summary_wrap {
        grid-area: summary;
      }
      .product_journeys_wrap {
        grid-area: journeys;
      }
      .product_details_wrap {
        grid-area: details;
      }
      .product_complements_wrap {
        grid-area: complements;
      }
      .product_links_wrap {
        grid-area: links;
      }
    }
    .product_gallery_thumb_slider_wrap {
      --_gap---size: 0.5rem;
    }
    @container (width >= 53em) {
      .product_story_card.is-image-large {
        grid-column: span 2;
        aspect-ratio: 6.57 / 6.4;
      }
      .product_story_heading {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
    }
  </style>
