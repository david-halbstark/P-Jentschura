{% assign selected_collection = section.settings.collection -%}
{%- assign theme_metaobject = selected_collection.metafields.custom.theme_color.value -%}
{%- assign theme_color = theme_metaobject.color.value | color_to_hex %}
<div class="u-embed-css w-embed">
  <style>
    .product_slider_layout:not([data-script-initialized='true']) .product_slider_tab:first-child {
      --_state---true: 0;
      --_state---false: 1;
    }
    .product_slider_layout:not([data-script-initialized='true']) .product_slider_panel:not(:first-child) {
      display: none;
    }
    .product_slider_slider_wrap {
      --_gap---size: 1rem;
    }
    @container (width < 75em) {
      .product_slider_bot .slider_offset {
        --slide-count: var(--md);
      }
    }
    @container (width < 60em) {
      .product_slider_bot .slider_offset {
        --slide-count: var(--sm);
      }
    }
    @container (width < 40em) {
      .product_slider_bot .slider_offset {
        --slide-count: var(--xs);
      }
    }
    #shopify-section-{{ section.id }}.product_slider_wrap {
      --collection-theme-color: {{ theme_color }};
    }
  </style>
</div>
<div class="u-display-none"></div>

<div class="u-display-none">
  {% case section.settings.spacing_top -%}
    {%- when 'xxsmall' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--xxsmall)' -%}
    {%- when 'xsmall' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--xsmall)' -%}
    {%- when 'small' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--small)' -%}
    {%- when 'medium' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--medium)' -%}
    {%- when 'large' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--large)' -%}
    {%- when 'large_medium_off' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--large-medium-off)' -%}
    {%- when 'page_top' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--page-top)' -%}
    {%- else -%}
      {%- assign spacing_top = '0' -%}
  {%- endcase -%}
  {%- case section.settings.spacing_bottom -%}
    {%- when 'xxsmall' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--xxsmall)' -%}
    {%- when 'xsmall' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--xsmall)' -%}
    {%- when 'small' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--small)' -%}
    {%- when 'medium' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--medium)' -%}
    {%- when 'large' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--large)' -%}
    {%- when 'page_top' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--page-top)' -%}
    {%- else -%}
      {%- assign spacing_bottom = '0' -%}
  {%- endcase %}
  <div class="u-embed-css w-embed">
    <style>
      #shopify-section-{{ section.id }} [data-section-spacing] {
        --section-spacing-top: {{ spacing_top }};
        --section-spacing-bottom: {{ spacing_bottom }};
      }
    </style>
  </div>
</div>
<div class="u-display-none"></div>
<div class="u-display-none"></div>

<div
  class="product_slider_contain u-container"
  {% if section.settings.section_id != blank %}
    id="{{ section.settings.section_id }}"
  {% endif %}
>
  <div data-section-spacing="" class="product_slider_layout">
    <div class="product_slider_top">
      <div class="product_slider_top_left u-margin-trim">
        {% render 'eyebrow',
          wrapper_class: 'is-eyebrow-base',
          eyebrow: section.settings.eyebrow,
          variant: 'u-text-eyebrow-base',
          custom_class: 'u-color-3'
        %}
        {% render 'heading',
          tag: section.settings.heading_tag,
          visually_hidden: section.settings.heading_visually_hidden,
          tidy_text: section.settings.heading_tidy_text,
          heading: section.settings.heading,
          custom_class: 'u-margin-bottom-0',
          variant: 'u-text-h2-primary',
          max_width: section.settings.heading_max_width
        %}
      </div>
      <div class="product_slider_top_right">
        <div class="product_slider_link">
          {% render 'typography',
            custom_attribute_value: 'true',
            text: section.settings.clickable_label,
            tag: 'span',
            variant: 'u-text-link-base',
            custom_class: 'u-margin-bottom-0 u-min-width-auto',
            custom_attribute_name: 'aria-hidden'
          %}
          {% render 'clickable', url: section.settings.clickable_url, label: section.settings.clickable_label %}
        </div>
      </div>
    </div>
    <div class="product_slider_bot">
      <div class="product_slider_slider_wrap slider_wrap">
        <div style="--lg: 4; --md: 2.5; --sm: 1.9; --xs: 1.1;" class="product_slider_slider_offset slider_offset">
          <div class="product_slider_slider_element swiper">
            <div class="product_slider_slider_list swiper-wrapper">
              <div class="product_slider_slider_slide is-first swiper-slide">
                {% render 'product_teaser_card',
                  paragraph: section.settings.teaser_card_paragraph,
                  button_url: section.settings.teaser_card_button_url,
                  heading_tag: section.settings.teaser_card_heading_tag,
                  button_label: section.settings.teaser_card_button_label,
                  heading: section.settings.teaser_card_heading,
                  eyebrow_tag: section.settings.teaser_card_eyebrow_tag,
                  eyebrow: section.settings.teaser_card_eyebrow
                %}
              </div>
              {% for product in selected_collection.products %}
                <div li-for="product in selected_collection.products" class="product_slider_slider_slide swiper-slide">
                  {% assign product_story = product.metafields.custom.product_story.value -%}
                  {%- assign top_image = product_story.top_image.value %}

                  {% render 'product_card',
                    product_hover_button_label: section.settings.product_card_button_label,
                    product_url: product.url,
                    product_hover_image: top_image,
                    product_title: product.title,
                    product_tag: product.metafields.custom.hero_eyebrow,
                    product_image: product.images.first,
                    product_description: product.description
                  %}
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
        <div class="slider_controls">
          <div class="slider_bullet_list">
            <div class="slider_bullet_item is-active"></div>
            <div class="slider_bullet_item"></div>
          </div>
          <div class="slider_button_layout">
            <button data-trigger="hover focus" class="slider_button_wrap is-prev">
              <div class="slider_button_element">
                <div class="slider_button_icon">
                  {% render 'icon', aria-hidden: true, icon: 'arrow_left' %}
                </div>
              </div></button
            ><button data-trigger="hover focus" class="slider_button_wrap is-next">
              <div class="slider_button_element">
                <div class="slider_button_icon">
                  {% render 'icon', aria-hidden: true, icon: 'arrow_right' %}
                </div>
              </div>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="u-embed-js w-embed w-script">
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('.product_slider_layout').forEach((component) => {
        if (component.dataset.scriptInitialized === 'true') return;
        component.dataset.scriptInitialized = 'true';
        const swiperElement = component.querySelector('.product_slider_slider_element.swiper');
        if (!swiperElement || swiperElement.swiper) return;
        const sliderWrap = swiperElement.closest('.product_slider_slider_wrap');
        if (!sliderWrap) return;
        const previousButton = sliderWrap.querySelector('.slider_button_wrap.is-prev');
        const nextButton = sliderWrap.querySelector('.slider_button_wrap.is-next');
        const pagination = sliderWrap.querySelector('.slider_bullet_list');
        new Swiper(swiperElement, {
          slidesPerView: 'auto',
          navigation: {
            prevEl: previousButton,
            nextEl: nextButton,
            disabledClass: 'is-disabled',
          },
          pagination: {
            el: pagination,
            clickable: true,
            bulletClass: 'slider_bullet_item',
            bulletActiveClass: 'is-active',
            renderBullet(index, className) {
              return `
                <button
                  type="button"
                  class="${className}"
                  aria-label="Slide ${index + 1}"
                ></button>
              `;
            },
          },
        });
      });
    });
  </script>
</div>

<style>
      h2 a em {
        display: inline-block;
        white-space: nowrap;
        font-style: inherit;

  color: red;    }

      h2 a em::after {
  content: "\00a0";
  display: inline-block;
  width: 0.8em;
  height: 0.8em;
  margin-inline-start: 0.2em;
  vertical-align: -0.05em;

        background-image: url("{{ 'arrow-up-right.svg' | asset_url }}");
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
      }
</style>
