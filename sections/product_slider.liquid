<div class="u-embed-css w-embed">
  <style>
    .product_slider_slider_wrap {
      --_gap---size: 1rem;
    }
    .product_teaser_card_top::before {
      content: '';
      width: 50%;
      height: 100%;
      position: absolute;
      left: 50%;
      top: 0%;
      right: auto;
      bottom: 0%;
      background-color: var(--swatch--white-o20);
      transform: translateX(-50%);
    }
    .product_teaser_card_bot .u-button-wrapper {
      margin-top: 0rem;
    }
    .product_teaser_card_element {
      background-color: var(--collection-theme-color, grey);
    }
    .product_card_tag .tag_wrap {
      background-color: var(--collection-theme-color, grey);
    }
    .product_teaser_card_button_wrap {
      transition: grid-template-rows 0.2s ease;
    }
    .product_teaser_card_wrap:has(:hover, :focus-visible) .product_teaser_card_button_wrap {
      grid-template-rows: 1fr;
    }
    @media (hover: none) {
      .product_teaser_card_button_wrap {
        grid-template-rows: 1fr;
      }
    }
    @container (width < 75em) {
      .product_slider_mid .slider_offset {
        --slide-count: var(--md);
      }
    }
    @container (width < 45em) {
      .product_slider_mid .slider_offset {
        --slide-count: var(--sm);
      }
    }
    @container (width < 35em) {
      .product_slider_mid .slider_offset {
        --slide-count: var(--xs);
      }
    }
  </style>
</div>
<div class="u-display-none"></div>

<div class="u-display-none">
  {% case section.settings.spacing_top -%}
    {%- when 'xxsmall' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--xxsmall)' -%}
    {%- when 'xsmall' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--xsmall)' -%}
    {%- when 'small' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--small)' -%}
    {%- when 'medium' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--medium)' -%}
    {%- when 'large' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--large)' -%}
    {%- when 'large_medium_off' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--large-medium-off)' -%}
    {%- when 'page_top' -%}
      {%- assign spacing_top = 'var(--_spacing---section-space--page-top)' -%}
    {%- else -%}
      {%- assign spacing_top = '0' -%}
  {%- endcase -%}
  {%- case section.settings.spacing_bottom -%}
    {%- when 'xxsmall' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--xxsmall)' -%}
    {%- when 'xsmall' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--xsmall)' -%}
    {%- when 'small' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--small)' -%}
    {%- when 'medium' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--medium)' -%}
    {%- when 'large' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--large)' -%}
    {%- when 'page_top' -%}
      {%- assign spacing_bottom = 'var(--_spacing---section-space--page-top)' -%}
    {%- else -%}
      {%- assign spacing_bottom = '0' -%}
  {%- endcase %}
  <div class="u-embed-css w-embed">
    <style>
      #shopify-section-{{ section.id }} [data-section-spacing] {
        --section-spacing-top: {{ spacing_top }};
        --section-spacing-bottom: {{ spacing_bottom }};
      }
    </style>
  </div>
</div>
<div class="u-display-none"></div>
<div class="u-display-none"></div>

<div
  class="product_slider_contain u-container"
  id="{% if section.settings.section_id != blank %}{{ section.settings.section_id }}{% endif %}"
>
  <div data-section-spacing="" class="product_slider_layout">
    <div class="product_slider_top">
      <div class="product_slider_top_left u-margin-trim">
        {% render 'eyebrow',
          wrapper_class: 'is-eyebrow-base',
          eyebrow: section.settings.eyebrow,
          variant: 'u-text-eyebrow-base',
          custom_class: 'u-color-3'
        %}
        {% render 'heading', tag: section.settings.heading_tag, visually_hidden: section.settings.heading_visually_hidden, tidy_text: section.settings.heading_tidy_text, heading: section.settings.heading, custom_class: , variant: 'u-text-h2-primary', max_width: section.settings.heading_max_width %}
      </div>
      <div class="product_slider_top_right">
        <div class="product_slider_tabs">
          <div class="product_slider_tabs_inner">
            {% for block in section.blocks %}
              {% if block.type == 'tab-panel' %}
                <button li-block="Tab + Panel" class="product_slider_tab">
                  <div class="u-display-none"></div>

                  {% render 'typography',
                    custom_class: 'u-margin-bottom-0 u-min-width-auto',
                    text: block.settings.tab_text,
                    tag: 'span',
                    variant: 'u-text-link-base'
                  %}
                </button>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        <div class="product_slider_link">
          {% render 'typography',
            custom_class: 'u-margin-bottom-0 u-min-width-auto',
            text: section.settings.link_text,
            tag: 'span',
            variant: 'u-link-base'
          %}
          {% render 'clickable', url: section.settings.clickable_url, label: section.settings.clickable_label %}
        </div>
      </div>
    </div>
    <div class="product_slider_mid">
      {% if section.settings.display_type == 'tabs' %}
        <div li-if="section.settings.display_type == 'tabs'" class="product_slider_panels">
          {% for block in section.blocks %}
            <div li-for="block in section.blocks" class="product_slider_panel">
              {% assign selected_collection = block.settings.collection -%}
              {%- assign theme_metaobject = selected_collection.metafields.custom.theme_color.value -%}
              {%- assign theme_color = theme_metaobject.color.value | color_to_hex %}

              <div class="u-embed-css w-embed">
                <style>
                  #product-slider-block-{{ block.id }} {
                    --collection-theme-color: {{ theme_color }};
                  }
                </style>
              </div>

              <div id="product-slider-block-{{ block.id }}" class="product_slider_slider_wrap">
                <div
                  style="--lg: 4; --md: 2.5; --sm: 1.9; --xs: 1.1;"
                  class="product_slider_slider_offset slider_offset"
                >
                  <div class="product_slider_slider_element swiper">
                    <div class="product_slider_slider_list swiper-wrapper">
                      <div class="product_slider_slider_slide is-first swiper-slide">
                        {% render 'product_teaser_card',
                          paragraph: block.settings.teaser_card_paragraph,
                          button_url: block.settings.teaser_card_button_url,
                          heading_tag: block.settings.teaser_card_heading_tag,
                          button_label: block.settings.teaser_card_button_label,
                          heading: block.settings.teaser_card_heading,
                          eyebrow_tag: block.settings.teaser_card_eyebrow_tag,
                          eyebrow: block.settings.teaser_card_eyebrow
                        %}
                      </div>
                      {% for product in selected_collection.products %}
                        <div
                          li-for="product in selected_collection.products"
                          class="product_slider_slider_slide swiper-slide"
                        >
                          <div class="product_slider_product_card">
                            {% assign product_story = product.metafields.custom.product_story.value -%}
                            {%- assign top_image = product_story.top_image.value %}
                            {% render 'product_card',
                              product_url: product.url,
                              product_tag: product.metafields.custom.hero_eyebrow,
                              product_image: product.title,
                              product_description: product.description,
                              product_hover_image: top_image
                            %}
                          </div>
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
      {% if section.settings.display_type == 'collection' %}
        <div li-if="section.settings.display_type == 'collection'" class="product_slider_collection">
          {% assign selected_collection = block.settings.collection -%}
          {%- assign theme_metaobject = selected_collection.metafields.custom.theme_color.value -%}
          {%- assign theme_color = theme_metaobject.color.value | color_to_hex %}
          <div class="u-embed-css w-embed">
            <style>
              #shopify-section-{{ section.id }} .product_slider_wrap
                --collection-theme-color: {{ theme_color }};
              }
            </style>
          </div>
          <div class="product_slider_slider_wrap">
            <div style="--lg: 4; --md: 2.5; --sm: 1.9; --xs: 1.1;" class="product_slider_slider_offset slider_offset">
              <div class="product_slider_slider_element swiper">
                <div class="product_slider_slider_list swiper-wrapper">
                  <div class="product_slider_slider_slide is-first swiper-slide">
                    {% render 'product_teaser_card',
                      paragraph: block.settings.teaser_card_paragraph,
                      button_url: block.settings.teaser_card_button_url,
                      heading_tag: block.settings.teaser_card_heading_tag,
                      button_label: block.settings.teaser_card_button_label,
                      heading: block.settings.teaser_card_heading,
                      eyebrow_tag: block.settings.teaser_card_eyebrow_tag,
                      eyebrow: block.settings.teaser_card_eyebrow
                    %}
                  </div>
                  {% for product in selected_collection.products %}
                    <div
                      li-for="product in selected_collection.products"
                      class="product_slider_slider_slide swiper-slide"
                    >
                      <div class="product_slider_product_card">
                        {% assign product_story = product.metafields.custom.product_story.value -%}
                        {%- assign top_image = product_story.top_image.value %}
                        {% render 'product_card',
                          product_url: product.url,
                          product_tag: product.metafields.custom.hero_eyebrow,
                          product_image: product.title,
                          product_description: product.description,
                          product_hover_image: top_image
                        %}
                      </div>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
    <div class="product_slider_bot">
      <div class="slider_controls">
        <div class="slider_bullet_list">
          <div class="slider_bullet_item is-active"></div>
          <div class="slider_bullet_item"></div>
        </div>
        <div class="slider_button_layout">
          <button data-trigger="hover focus" class="slider_button_wrap">
            <div class="slider_button_element">
              <div class="slider_button_icon">
                {% render 'icon', aria-hidden: true, icon: 'arrow_left' %}
              </div>
            </div></button
          ><button data-trigger="hover focus" class="slider_button_wrap">
            <div class="slider_button_element">
              <div class="slider_button_icon">
                {% render 'icon', aria-hidden: true, icon: 'arrow_right' %}
              </div>
            </div>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
