        <div class="u-embed-js w-embed w-script">
          <script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.hero_main_slider_wrap').forEach((component) => {
      if (component.dataset.scriptInitialized) return;
      component.dataset.scriptInitialized = 'true';
      const slider = component.querySelector('.hero_main_slider_element');
      const pagination = component.querySelector('.hero_main_slider_bullet_list');
      const slides = component.querySelectorAll('.hero_main_slide_wrap');
      if (!slider || typeof Swiper === 'undefined') return;
      const hasMultipleSlides = slides.length > 1;
      const swiper = new Swiper(slider, {
        slidesPerView: 'auto',
        loop: hasMultipleSlides,
        autoplay: hasMultipleSlides
          ? {
              delay: 4500,
              disableOnInteraction: true,
            }
          : false,
        keyboard: {
          enabled: true,
          onlyInViewport: true,
        },
        pagination: pagination
          ? {
              el: pagination,
              bulletClass: 'hero_main_slider_bullet_item',
              bulletActiveClass: 'is-active',
              clickable: true,
              renderBullet(index, className) {
                return `
                <button
                  class="${className}"
                  type="button"
                  aria-label="Zu Slide ${index + 1}"
                ></button>
              `;
              },
            }
          : false,
      });
      if (!hasMultipleSlides || !swiper.autoplay) return;
      swiper.autoplay.pause();
      const autoplayObserver = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            swiper.autoplay.resume();
          } else {
            swiper.autoplay.pause();
          }
        },
        {
          threshold: 0.5,
        },
      );
      autoplayObserver.observe(component);
    });
  });
</script>
