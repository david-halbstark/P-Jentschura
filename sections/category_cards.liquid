<div class="u-embed-css w-embed">
          <style>
  @container (width < 70em) {
    .category_cards_layout {
      --_column-count---value: 2;
    }
  }
  @container (width < 40em) {
    .category_cards_layout {
      --_column-count---value: 1;
    }
    .category_cards_card_element {
      flex-flow: row wrap;
      padding: 1.25rem;
      gap: 1rem;
    }
    .category_card_icon {
      width: 2.75rem;
    }
    .category_card_bot {
      gap: 0.625rem;
    }
    .category_card_bot {
      flex: 1 1 12rem;
      align-items: flex-start;
      text-align: start;
    }
  }
  .category_cards_card_element:before {
    content: '';
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
    background-image: linear-gradient(#f2f1f1 0%, #ededed 100%);
    opacity: calc(100% * var(--_trigger---off));
    transition: opacity 0.2s ease;
  }
  .category_card_bot_text:has(> :nth-child(2)) > :first-child:after {
    content: ' \2022  ';
    color: var(--_theme---text-5);
  }
  .category_card_bot_text span {
    display: inline-block;
  }
</style>
        </div>
        <div class="u-display-none">
          
          
        </div>
        <div class="u-display-none">
          
          
          
        </div>
        <div class="u-display-none">
          
          
        </div>
        <div class="u-display-none">
          
          
        </div>
        <div class="u-display-none">
          
          
          
          
          
          
        </div>
        <div class="category_cards_contain u-container" id="{% if section.settings.section_id != blank %}{{ section.settings.section_id }}{% endif %}">
          {% render 'spacer', variant: section.settings.spacing_top %}
          <div class="category_cards_layout u-grid-custom">
            {% render 'heading', custom_class: , heading: section.settings.heading, tag: h2, visually_hidden: true %}
            {% for block in section.blocks %}
    {% if block.type == "card" %}
                    <div li-block="Card" class="category_cards_card_wrap">
                                    
              
                                    <div class="u-display-none">
                
                
                
              </div>
                                    
              
                                    <div class="u-display-none">
                
                
              </div>
                                    
              
                                    <div class="u-display-none">
                
              </div>
                                    
              
                                    <div class="u-display-none">
                
                
              </div>
                                    
              
                                    <div data-trigger="hover focus" class="category_cards_card_component">
                <div class="category_cards_card_element">
                  <div class="category_card_top">
                    <div class="category_card_icon">
                      {% render 'image', width: 132, image: section.settings.image, object_fit: 'contain' %}
                    </div>
                  </div>
                  <div class="category_card_bot">
                    {% render 'heading', custom_class: 'u-margin-bottom-0', heading: block.settings.heading, tag: 'h3', variant: 'u-text-h3-secondary' %}
                    <div class="category_card_bot_text">
                      <div class="u-display-contents">
                        {% render 'typography', custom_class: 'u-margin-bottom-0 u-min-width-auto', text: block.settings.text_1, tag: 'span', variant: 'u-text-body-small' %}
                      </div>
                      <div class="u-display-contents">
                        {% render 'typography', custom_class: 'u-margin-bottom-0 u-min-width-auto', text: block.settings.text_2, tag: 'span', variant: 'u-text-body-small' %}
                      </div>
                    </div>
                  </div>
                </div>
                {% render 'clickable', url: block.settings.clickable_url, label: section.settings.heading, mode: 'link' %}
              </div>
                                    
            
                            </div>
            {% endif %}
{% endfor %}
            <div>
              {% render 'tag', custom_class: , tag: section.settings.tag, variant: section.settings.tag_variant, solid_text_size: section.settings.tag_solid_text_size, solid_color: section.settings.tag_solid_color, pill_text_size: section.settings.tag_pill_text_size %}
            </div>
          </div>
          {% render 'spacer', variant: section.settings.spacing_bottom %}
