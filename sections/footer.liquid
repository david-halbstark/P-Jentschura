<div class="u-embed-css w-embed">
  <style>
    @container (width >= 70em) {
      .footer_bot_right:has(.footer_lang_wrap) .footer_bot_list::after {
        content: '';
        display: block;
        margin-inline: 0.5rem;
        height: 1.75rem;
        width: 0.0625rem;
        background-color: var(--_theme---background);
      }
    }
    @container (width < 70em) {
      .footer_bot_right {
        order: -999;
      }
      .footer_bot_layout {
        padding-top: 2.5rem;
        padding-bottom: 3.75rem;
      }
      .footer_bot_right {
        row-gap: 2rem;
        margin: 0rem;
      }
      .footer_bot_layout,
      .footer_bot_right {
        flex-flow: column;
        align-items: start;
      }
      .footer_bot_list,
      .footer_lang_dd_button {
        margin: calc(calc(-0.5rem * var(--_responsive---large)) + calc(-0.625rem * max(var(--_responsive---medium), var(--_responsive---small), var(--_responsive---xsmall))));
      }
      .footer_mid_layout {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      }
      .footer_lang_dd_button {
        margin-left: -0.75rem;
      }
      .footer_lang_dd_list_wrap {
        left: -0.75rem;
        right: auto;
      }
    }
    .footer_group_item_element > .u-text,
    .footer_bottom_item_text > .u-text {
      text-decoration-line: underline;
      text-decoration-color: color-mix(in srgb, var(--swatch--transparent) calc(100% * var(--_trigger---on)), currentColor calc(100% * var(--_trigger---off)));
      text-underline-offset: 0.125em;
    }
    .footer_group_item_tag .tag_wrap {
      padding: 0.3125rem 0.5rem;
    }
    .footer_group_item_tag .tag_text {
      font-weight: var(--_typography---font--primary-semibold);
      font-size: 0.625rem;
    }
    .footer_lang_dd_list_wrap[data-position='bottom'] {
      top: calc(100% + calc(calc(0.5rem * var(--_responsive---large)) + calc(0.25rem * max(var(--_responsive---medium), var(--_responsive---small), var(--_responsive---xsmall)))));
      bottom: auto;
    }
    .footer_lang_dd_list_wrap[data-position='top'] {
      top: auto;
      bottom: calc(100% + calc(calc(0.5rem * var(--_responsive---large)) + calc(0.25rem * max(var(--_responsive---medium), var(--_responsive---small), var(--_responsive---xsmall)))));
    }
  </style>
</div>
<div class="u-embed-css w-embed">
  <style>
    @container (width < 50em) {
      .footer_mid_layout {
        display: flex;
        flex-flow: column;
        gap: 0rem;
        padding-top: calc(var(--_spacing---section-space--main) - 1.5rem);
        padding-bottom: var(--_spacing---section-space--main);
      }
      .footer_column {
        align-items: stretch;
        display: contents;
      }
      .footer_group_element {
        gap: 0rem;
        border-bottom: solid 0.0625rem color-mix(in srgb, var(--_theme---background-7) 10%, transparent 90%);
      }
      .footer_group_bot_wrap {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.2s ease;
      }
      .footer_group_bot_element {
        overflow: hidden;
      }
      .footer_group_top {
        display: flex;
        justify-content: space-between;
        column-gap: 1rem;
        color: var(--_theme---text);
      }
      .footer_group_top > .u-heading {
        width: 100%;
      }
      .footer_group_top > .u-text-eyebrow-base {
        --_text-style-1---font-size: var(--_typography---font-size--eyebrow-large);
        --_text-style-1---letter-spacing: var(--_typography---letter-spacing--wide);
      }
      .footer_group_top_icon_wrap {
        display: flex;
      }
      .footer_mid_layout:not(:has([data-footer-accordions-initialized='true'])) .footer_column:first-child .footer_group_bot_wrap,
      .footer_group_wrap.is-open .footer_group_bot_wrap {
        grid-template-rows: 1fr;
      }
      .footer_mid_layout:not(:has([data-footer-accordions-initialized='true'])) .footer_column:first-child .footer_group_top_icon,
      .footer_group_wrap.is-open .footer_group_top_icon {
        transform: rotate(180deg);
      }
      .footer_group_list {
        padding-bottom: 2rem;
      }
    }
  </style>
</div>
