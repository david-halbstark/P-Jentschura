{% render 'heading', visually_hidden: true, heading: section.settings.heading, tag: 'h2' %}
<div class="footer_top_wrap">
  <div class="footer_top_contain u-container">
    <div class="footer_top_layout">
      <div class="footer_top_text">
        {% render 'typography',
          custom_class: 'u-margin-bottom-0',
          text: section.settings.socials_text,
          tag: 'div',
          variant: 'u-text-eyebrow-large'
        %}
      </div>
      <div role="list" class="footer_social_wrap">
        {% for block in section.blocks %}
          {% if block.type == 'socials-item' %}
            <div role="listitem" li-block="Socials Item" class="footer_social_item_wrap">
              <div class="u-display-none"></div>

              <div data-trigger="hover focus" class="footer_socials_item_element">
                <div class="footer_socials_item_inner">
                  <div class="footer_socials_item_icon">
                    {% render 'icon', aria-hidden: true, icon: block.settings.icon %}
                  </div>
                </div>
                {% render 'clickable',
                  target: '_blank',
                  label: block.settings.clickable_label,
                  mode: 'link',
                  url: block.settings.clickable_url
                %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>
<div class="footer_mid_wrap">
  <div class="footer_mid_contain u-container">
    <nav data-element="footer-container" class="footer_mid_layout">
      {% assign footer_columns = '1,2,3,4' | split: ',' %}
      {% if false %}
        <div li-if="false" class="u-display-none">
          {% for block in section.blocks %}
            {% if block.type == 'group' %}
              <div data-trigger="group" li-block="Group" class="u-display-none">
                <div class="u-display-none"></div>

                {% render 'footer_group', footer_group: block %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
      {% for column_number in footer_columns %}
        <div li-for="column_number in footer_columns" class="footer_column">
          {% for block in section.blocks -%}
            {%- if block.type != 'group' %}{% continue %}{% endif -%}
            {%- if block.settings.desktop_column != column_number %}{% continue %}{% endif -%}
            {%- render 'footer_group', footer_group: block -%}
          {%- endfor %}
        </div>
      {% endfor %}
    </nav>
  </div>
</div>
<div class="footer_bot_wrap">
  <div class="footer_bot_contain u-container">
    <div class="footer_bot_layout">
      <div class="footer_bot_left">
        {% render 'typography',
          custom_class: 'u-margin-bottom-0',
          text: section.settings.legal_text,
          tag: 'div',
          variant: 'u-text-body-small'
        %}
      </div>
      <div role="list" class="footer_bot_right">
        <div role="list" data-trigger="group" class="footer_bot_list">
          {% for link in section.settings.menu.links %}
            <div
              li-for="link in section.settings.menu.links"
              data-trigger="hover focus"
              role="listitem"
              class="footer_bottom_item"
            >
              <div aria-hidden="true" class="footer_bottom_item_text">
                {% render 'typography',
                  custom_class: 'u-margin-bottom-0',
                  text: link.title,
                  tag: 'div',
                  variant: 'u-text-link-small'
                %}
              </div>

              {% render 'clickable', target: '_self', label: link.title, mode: 'link', url: link.url %}
            </div>
          {% endfor %}
        </div>
        {% if localization.available_languages.size > 1 %}
          <localization-form li-if="localization.available_languages.size > 1" class="footer_lang_wrap">
            {% form 'localization', class: 'footer_lang_form' %}
              <div data-dropdown="" class="footer_lang_dd">
                <button
                  type="button"
                  data-dropdown-trigger=""
                  aria-expanded="false"
                  lang="{{ localization.language.iso_code }}"
                  data-trigger="hover focus"
                  class="footer_lang_dd_button"
                >
                  {% render 'typography', custom_class: 'u-margin-bottom-0 u-min-width-auto', text: localization.language.name | capitalize, tag: 'span', variant: 'u-text-link-small' %}
                  <div class="footer_lang_dd_icon">
                    {% render 'icon', aria-hidden: true, icon: 'chevron_down' %}
                  </div>
                </button>
                <div hidden="" data-dropdown-menu="" class="footer_lang_dd_list_wrap">
                  <ul li-for:inside="language in localization.available_languages" class="footer_lang_dd_list">
                    {% for language in localization.available_languages %}
                      {% unless localization.language.iso_code == language.iso_code %}
                        <li li-unless="localization.language.iso_code == language.iso_code" class="footer_lang_dd_item">
                          <a
                            data-trigger="hover focus"
                            lang="{{ language.iso_code }}"
                            hreflang="{{ language.iso_code }}"
                            data-value="{{ language.iso_code }}"
                            href="#"
                            class="footer_lang_dd_link w-inline-block"
                          >
                            {% render 'typography', custom_class: 'u-margin-bottom-0 u-min-width-auto', text: language.name | capitalize, tag: 'span', variant: 'u-text-link-small' %}
                          </a>
                        </li>
                      {% endunless %}
                    {% endfor %}
                  </ul>
                </div>
              </div>
              <input
                type="hidden"
                name="language_code"
                class="footer_lang_hidden_input"
                value="{{ localization.language.iso_code }}"
              >
            {% endform %}
          </localization-form>
        {% endif %}
      </div>
    </div>
  </div>
</div>
<div class="u-embed-js w-embed w-script">
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      let dropdownId = 0;
      document.querySelectorAll('[data-dropdown]').forEach((component) => {
        if (component.dataset.scriptInitialized === 'true') return;
        const trigger = component.querySelector('[data-dropdown-trigger]');
        const menu = component.querySelector('[data-dropdown-menu]');
        if (!trigger || !menu) return;
        component.dataset.scriptInitialized = 'true';
        dropdownId += 1;
        const triggerId = trigger.id || `dropdown-trigger-${dropdownId}`;
        const menuId = menu.id || `dropdown-menu-${dropdownId}`;
        trigger.id = triggerId;
        menu.id = menuId;
        trigger.setAttribute('aria-controls', menuId);
        trigger.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-labelledby', triggerId);
        menu.hidden = true;
        function isOpen() {
          return trigger.getAttribute('aria-expanded') === 'true';
        }
        function setDropdownPosition() {
          const triggerRect = trigger.getBoundingClientRect();
          const viewportPadding = 16;
          const dropdownGap = 8;
          const spaceBelow = window.innerHeight - triggerRect.bottom - dropdownGap - viewportPadding;
          const spaceAbove = triggerRect.top - dropdownGap - viewportPadding;
          const menuHeight = menu.scrollHeight;
          const openAbove = menuHeight > spaceBelow && spaceAbove > spaceBelow;
          const availableSpace = openAbove ? spaceAbove : spaceBelow;
          menu.dataset.position = openAbove ? 'top' : 'bottom';
          menu.style.maxHeight = `${Math.max(100, availableSpace)}px`;
        }
        function openDropdown() {
          menu.hidden = false;
          setDropdownPosition();
          component.classList.add('is-active');
          trigger.setAttribute('aria-expanded', 'true');
        }
        function closeDropdown(options = {}) {
          const { returnFocus = false } = options;
          if (!isOpen()) return;
          menu.hidden = true;
          component.classList.remove('is-active');
          trigger.setAttribute('aria-expanded', 'false');
          menu.removeAttribute('data-position');
          menu.style.removeProperty('max-height');
          if (returnFocus) {
            trigger.focus();
          }
        }
        function toggleDropdown() {
          if (isOpen()) {
            closeDropdown();
          } else {
            openDropdown();
          }
        }
        trigger.addEventListener('click', function () {
          toggleDropdown();
        });
        document.addEventListener('click', function (event) {
          if (!isOpen()) return;
          if (component.contains(event.target)) return;
          closeDropdown();
        });
        document.addEventListener('keydown', function (event) {
          if (event.key !== 'Escape') return;
          if (!isOpen()) return;
          closeDropdown({ returnFocus: true });
        });
        window.addEventListener('resize', function () {
          if (!isOpen()) return;
          setDropdownPosition();
        });
        window.addEventListener(
          'scroll',
          function () {
            if (!isOpen()) return;
            setDropdownPosition();
          },
          true
        );
      });
    });
  </script>
</div>
<div class="u-embed-js w-embed w-script">
  <script>
    (() => {
      if (customElements.get('localization-form')) {
        return;
      }
      class LocalizationForm extends HTMLElement {
        constructor() {
          super();
          this.onClick = this.onClick.bind(this);
        }
        connectedCallback() {
          this.addEventListener('click', this.onClick);
        }
        disconnectedCallback() {
          this.removeEventListener('click', this.onClick);
        }
        onClick(event) {
          const link = event.target.closest('a[data-value]');
          if (!link || !this.contains(link)) return;
          event.preventDefault();
          const form = this.querySelector('form');
          const input = this.querySelector('input[name="language_code"], input[name="country_code"]');
          if (!form || !input) return;
          input.value = link.dataset.value;
          form.submit();
        }
      }
      customElements.define('localization-form', LocalizationForm);
    })();
  </script>
</div>
<div class="u-embed-js w-embed w-script">
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const container = document.querySelector('[data-element="footer-container"]');
      if (!container || typeof container.observeContainer !== 'function') {
        return;
      }
      const BUILD_ATTR = 'data-footer-accordion-built';
      function openAccordion(group, button, panel) {
        window.clearTimeout(group.openedClassTimeoutId);
        button.setAttribute('aria-expanded', 'true');
        group.classList.add('is-open');
        panel.inert = false;
        panel.removeAttribute('inert');
        group.openedClassTimeoutId = window.setTimeout(() => {
          group.classList.add('is-opened');
        }, 200);
      }
      function closeAccordion(group, button, panel) {
        window.clearTimeout(group.openedClassTimeoutId);
        button.setAttribute('aria-expanded', 'false');
        group.classList.remove('is-open');
        group.classList.remove('is-opened');
        panel.inert = true;
        panel.setAttribute('inert', '');
      }
      function toggleAccordion(group, button, panel) {
        const isOpen = button.getAttribute('aria-expanded') === 'true';
        if (isOpen) {
          closeAccordion(group, button, panel);
        } else {
          openAccordion(group, button, panel);
        }
      }
      function buildAccordions() {
        if (container.hasAttribute(BUILD_ATTR)) return;
        const groups = container.querySelectorAll('[data-element="footer-accordion-group"]');
        groups.forEach((group, groupIndex) => {
          const isInitialized = group.getAttribute('data-footer-accordions-initialized') === 'true';
          if (isInitialized) return;
          const top = group.querySelector('.footer_group_top');
          const title = top?.querySelector('h3');
          const panel = group.querySelector('[data-element="footer-accordion-panel"]');
          const icon = group.querySelector('[data-element="footer-accordion-icon"]');
          if (!top || !title || !panel) return;
          const accordionIndex = groupIndex + 1;
          const buttonId = `footer-accordion-${accordionIndex}-button`;
          const panelId = `footer-accordion-${accordionIndex}-panel`;
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'footer_accordion_button';
          button.setAttribute('data-element', 'footer-accordion-button');
          button.id = buttonId;
          button.setAttribute('aria-controls', panelId);
          button.setAttribute('aria-expanded', accordionIndex === 1 ? 'true' : 'false');
          while (title.firstChild) {
            button.appendChild(title.firstChild);
          }
          if (icon && !button.contains(icon)) {
            button.appendChild(icon);
          }
          title.appendChild(button);
          panel.id = panelId;
          panel.setAttribute('role', 'region');
          panel.setAttribute('aria-labelledby', buttonId);
          const interactiveElements = panel.querySelectorAll('a, button, input, select, textarea, [tabindex]');
          interactiveElements.forEach((element, elementIndex) => {
            if (!element.id) {
              element.id = `footer-accordion-${accordionIndex}` + `-item-${elementIndex + 1}`;
            }
          });
          button.addEventListener('click', () => {
            toggleAccordion(group, button, panel);
          });
          if (accordionIndex === 1) {
            openAccordion(group, button, panel);
          } else {
            closeAccordion(group, button, panel);
          }
          group.setAttribute('data-footer-accordions-initialized', 'true');
        });
        container.setAttribute(BUILD_ATTR, 'true');
      }
      function destroyAccordions() {
        if (!container.hasAttribute(BUILD_ATTR)) return;
        const groups = container.querySelectorAll('[data-element="footer-accordion-group"]');
        groups.forEach((group) => {
          const top = group.querySelector('.footer_group_top');
          const title = top?.querySelector('h3');
          const button = group.querySelector('[data-element="footer-accordion-button"]');
          const panel = group.querySelector('[data-element="footer-accordion-panel"]');
          if (!top || !title || !button || !panel) return;
          const icon = button.querySelector('[data-element="footer-accordion-icon"]');
          Array.from(button.childNodes).forEach((child) => {
            if (child !== icon) {
              title.insertBefore(child, button);
            }
          });
          if (icon) {
            top.appendChild(icon);
          }
          button.remove();
          panel.inert = false;
          panel.removeAttribute('inert');
          panel.removeAttribute('role');
          panel.removeAttribute('aria-labelledby');
          panel.removeAttribute('id');
          group.classList.remove('is-open', 'is-opened');
          window.clearTimeout(group.openedClassTimeoutId);
          group.removeAttribute('data-footer-accordions-initialized');
        });
        container.removeAttribute(BUILD_ATTR);
      }
      container.observeContainer('(width < 50em)', (match) => {
        if (match) {
          buildAccordions();
        } else {
          destroyAccordions();
        }
      });
    });
  </script>
</div>
